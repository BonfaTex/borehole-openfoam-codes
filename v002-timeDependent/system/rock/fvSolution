FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{

    "(h|e|hFinal|eFinal)"
    {
        solver           PCG;
        preconditioner   DIC;
        tolerance        1e-08; 
        relTol           0;    
    }
}

PIMPLE
{
    nOuterCorrectors 1;   
    nCorrectors      1;
    nNonOrthogonalCorrectors 0; 
}


