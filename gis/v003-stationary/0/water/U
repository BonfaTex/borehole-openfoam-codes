FoamFile
{
    version     2.0;
    format      ascii;
    arch        "LSB;label=32;scalar=64";
    class       volVectorField;
    location    "0/water";
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [ 0 1 -1 0 0 0 0 ];

internalField   uniform ( 0.25 0 0 );

boundaryField
{
    water_inlet
    {
        type            fixedValue;
        value           uniform ( 0.25 0 0 );
    }
    water_outlet
    {
        type            zeroGradient;
        value           uniform ( 0.01 0 0 );
    }
    water_wedge1
    {
        type            wedge;
        value           uniform ( 0 0 0 );
    }
    water_wedge2
    {
        type            wedge;
        value           uniform ( 0 0 0 );
    }
    water_to_rock
    {
        type            noSlip;
        value           uniform ( 0 0 0 );
    }
}


