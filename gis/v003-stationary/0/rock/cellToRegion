FoamFile
{
    version     2.0;
    format      ascii;
    arch        "LSB;label=32;scalar=64";
    class       volScalarField;
    location    "0/rock";
    object      cellToRegion;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 0 0 0 0];

internalField   uniform 1;

boundaryField
{
    rock_inlet
    {
        type            zeroGradient;
    }
    rock_outlet
    {
        type            zeroGradient;
    }
    rock_outer
    {
        type            zeroGradient;
    }
    rock_wedge1
    {
        type            wedge;
    }
    rock_wedge2
    {
        type            wedge;
    }
    rock_to_water
    {
        type            calculated;
        value           uniform 0;
    }
}


