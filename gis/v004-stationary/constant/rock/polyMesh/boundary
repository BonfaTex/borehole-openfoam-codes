FoamFile
{
    version     2.0;
    format      ascii;
    arch        "LSB;label=32;scalar=64";
    class       polyBoundaryMesh;
    location    "constant/rock/polyMesh";
    object      boundary;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

6
(
    rock_inlet
    {
        type            patch;
        nFaces          25;
        startFace       4875;
    }
    rock_outlet
    {
        type            patch;
        nFaces          25;
        startFace       4900;
    }
    rock_outer
    {
        type            patch;
        nFaces          100;
        startFace       4925;
    }
    rock_wedge1
    {
        type            wedge;
        inGroups        1(wedge);
        nFaces          2500;
        startFace       5025;
    }
    rock_wedge2
    {
        type            wedge;
        inGroups        1(wedge);
        nFaces          2500;
        startFace       7525;
    }
    rock_to_water
    {
        type            mappedWall;
        inGroups        1(wall);
        nFaces          100;
        startFace       10025;
        sampleMode      nearestPatchFace;
        sampleRegion    water;
        samplePatch     water_to_rock;
    }
)

