FoamFile
{
    version     2.0;
    format      ascii;
    arch        "LSB;label=32;scalar=64";
    class       volScalarField;
    location    "0/water";
    object      p_rgh;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [ 1 -1 -2 0 0 0 0 ];

internalField   uniform 100000;

boundaryField
{
    water_inlet
    {
        type            fixedFluxPressure;
        value           uniform 100000;
    }
    water_outlet
    {
        type            fixedValue;
        value           uniform 100000;
    }
    water_wedge1
    {
        type            wedge;
        value           uniform 100000;
    }
    water_wedge2
    {
        type            wedge;
        value           uniform 100000;
    }
    water_to_rock
    {
        type            fixedFluxPressure;
        value           uniform 100000;
    }
}


